{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "root": false,
  "extends": "//",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**/*.test.js", "!migrations", "!data"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveLinesPerFunction": "off"
      }
    }
  }
}
